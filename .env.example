# ===== Netlify Database (PostgreSQL) =====
# Lấy từ Netlify UI > Site settings > Environment variables (biến DATABASE_URL)
DATABASE_URL="postgresql://user:password@host:5432/netlifydb?sslmode=require"

# ===== VNPAY (thanh toán) =====
# TmnCode cấp bởi VNPAY khi đăng ký merchant
VNP_TMN_CODE=""
# HashSecret (TUYỆT ĐỐI BÍ MẬT - không commit file này)
VNP_HASH_SECRET=""
# Môi trường: sandbox (test) hoặc production
VNP_ENV="sandbox"
# URL cơ sở của site (dùng để build returnUrl & ipnUrl)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"